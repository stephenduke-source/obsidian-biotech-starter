filters:
    and:
        - categories.contains(link("Transcripts"))
        - file.folder != "Templates"
formulas:
properties:
    file.name:
        displayName: Transcript
    note.ensembl_id:
        displayName: Ensembl Transcript ID
    note.species:
        displayName: Species
    note.gene:
        displayName: Gene
    note.length:
        displayName: Length
    note.strand:
        displayName: Strand
    note.exons:
        displayName: Exons
    note.proteins:
        displayName: Proteins
    note.pathways:
        displayName: Pathways
    note.diseases:
        displayName: Diseases
    note.interactions:
        displayName: Interactions
    note.tissues:
        displayName: Tissues
    note.is_canonical:
        displayName: Is Canonical?
summaries:
views:
    - type: table
      name: Genes
      order:
        - file.name
        - ensembl_id
        - species
        - chromosome
        - pathways
        - diseases
        - interactions